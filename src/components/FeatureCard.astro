---
interface Props {
    title: string;
    desc: string;
    svg: string;
}

const { title, desc, svg } = Astro.props;
---

<div class="card-main">
    <div class="icon" set:html={svg} />
    <div class="text-content">
        <h3 class="title">{title}</h3>
        <p class="desc">{desc}</p>
    </div>
</div>

<style>
    .card-main {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: var(--space-lg);
        gap: var(--space-sm);
        background: var(--color-surface);
        border-radius: var(--radius-md);
        border: 1px solid var(--color-border);
    }

    .text-content{
        text-align: center;
    }

    .desc{
        text-wrap: balance;
    }

    .icon{
        margin-bottom: var(--space-lg);
    }
</style>
